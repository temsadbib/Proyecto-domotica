          "rawSql": "SELECT \"time\" AS \"time\", CASE entity_id WHEN 'sensor.sensor_temperatura_1_temperature' THEN 'T. Sensor 1' WHEN 'sensor.sensor_temperatura_2_temperature' THEN 'T. Sensor 2' WHEN 'sensor.sensor_temperatura_3_temperature' THEN 'T. Sensor 3' WHEN 'sensor.sensor_temperatura_4_temperature' THEN 'T. Sensor 4' WHEN 'sensor.mislata_temperatura' THEN 'T. Exterior' END AS metric, state_numeric AS value FROM silver_sensores WHERE entity_id IN ('sensor.sensor_temperatura_1_temperature','sensor.sensor_temperatura_2_temperature','sensor.sensor_temperatura_3_temperature','sensor.sensor_temperatura_4_temperature','sensor.mislata_temperatura') AND state_numeric IS NOT NULL AND $__timeFilter(\"time\") ORDER BY \"time\"",
