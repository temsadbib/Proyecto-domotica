          "rawQuery": true,
          "rawSql": "SELECT\n  CASE dia_de_la_semana\n    WHEN 1 THEN 'Lunes'\n    WHEN 2 THEN 'Martes'\n    WHEN 3 THEN 'Miércoles'\n    WHEN 4 THEN 'Jueves'\n    WHEN 5 THEN 'Viernes'\n  END AS \"Día\",\n  ROUND(AVG(CASE WHEN hora_del_dia = 8 THEN derroche_actual::numeric END) * 100) AS \"08h\",\n  ROUND(AVG(CASE WHEN hora_del_dia = 9 THEN derroche_actual::numeric END) * 100) AS \"09h\",\n  ROUND(AVG(CASE WHEN hora_del_dia = 10 THEN derroche_actual::numeric END) * 100) AS \"10h\",\n  ROUND(AVG(CASE WHEN hora_del_dia = 11 THEN derroche_actual::numeric END) * 100) AS \"11h\",\n  ROUND(AVG(CASE WHEN hora_del_dia = 12 THEN derroche_actual::numeric END) * 100) AS \"12h\",\n  ROUND(AVG(CASE WHEN hora_del_dia = 13 THEN derroche_actual::numeric END) * 100) AS \"13h\",\n  ROUND(AVG(CASE WHEN hora_del_dia = 14 THEN derroche_actual::numeric END) * 100) AS \"14h\",\n  ROUND(AVG(CASE WHEN hora_del_dia = 15 THEN derroche_actual::numeric END) * 100) AS \"15h\",\n  ROUND(AVG(CASE WHEN hora_del_dia = 16 THEN derroche_actual::numeric END) * 100) AS \"16h\",\n  ROUND(AVG(CASE WHEN hora_del_dia = 17 THEN derroche_actual::numeric END) * 100) AS \"17h\"\nFROM gold_derroche_historico\nWHERE dia_de_la_semana BETWEEN 1 AND 5\nGROUP BY dia_de_la_semana\nORDER BY dia_de_la_semana",
